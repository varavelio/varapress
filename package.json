{
  "name": "varapress",
  "version": "0.0.0",
  "description": "A clean, fast, and responsive all-in-one theme for Zola",
  "author": "Varavel",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varavelio/varapress.git"
  },
  "bugs": {
    "url": "https://github.com/varavelio/varapress/issues"
  },
  "homepage": "https://github.com/varavelio/varapress#readme",
  "scripts": {
    "ci": "npm run lint && npm run build",
    "dev": "concurrently 'npm run dev:css' 'npm run dev:js' 'npm run dev:zola'",
    "dev:zola": "zola serve",
    "dev:css": "npm run build:css -- --watch",
    "dev:js": "esbuild ./src/js/varapress.js --bundle --outfile=./static/js/varapress.js --watch",
    "build": "npm run build:css && npm run build:js && npm run build:theme-init && npm run build:zola",
    "build:zola": "rm -rf ./public && zola build",
    "build:css": "tailwindcss --minify --input ./src/css/varapress.css --output ./static/css/varapress.css",
    "build:js": "esbuild ./src/js/varapress.js --bundle --minify --outfile=./static/js/varapress.js",
    "build:theme-init": "esbuild ./src/js/theme-init.js --minify --outfile=./static/js/theme-init.js",
    "lint": "npm run lint:dprint && npm run lint:zola",
    "lint:dprint": "dprint check --config ./dprint.json --log-level warn",
    "lint:zola": "zola check",
    "format": "npm run format:dprint",
    "format:dprint": "dprint fmt --config ./dprint.json --log-level warn"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.0",
    "@tailwindcss/typography": "0.5.19",
    "alpinejs": "3.15.12",
    "concurrently": "9.2.1",
    "dprint": "0.54.0",
    "esbuild": "0.28.0",
    "tailwindcss": "4.3.0"
  }
}
